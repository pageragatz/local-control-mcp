# Last.fm API credentials
# Register at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_api_key_here
LASTFM_API_SECRET=your_api_secret_here

# Your Last.fm username (used as default for read tools)
LASTFM_USERNAME=your_lastfm_username

# Session key for write operations (love/scrobble/now-playing)
# Generate by running: uv run lastfm_auth.py
LASTFM_SESSION_KEY=

# MCP server settings (optional)
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_TRANSPORT=sse
